# サーバー設定
PORT=3000

# メール暗号化キー（本番環境では必ず変更）
ENCRYPTION_KEY=safety-map-change-this-key-in-production!

# Cloudinary設定（写真アップロード用）
# https://cloudinary.com/ で無料アカウント作成後に取得
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# または CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
